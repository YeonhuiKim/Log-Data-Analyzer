import sys
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget,
                              QTabWidget, QVBoxLayout, QHBoxLayout,
                              QPushButton, QLineEdit, QTableWidget,
                              QTableWidgetItem, QFileDialog, QLabel)
from PyQt5.QtCore import Qt
from PyQt5.QtGui import QColor
from log_parser import load_log

import matplotlib.pyplot as plt
from matplotlib.backends.backend_qt5agg import FigureCanvasQTAgg as FigureCanvas
import matplotlib.font_manager as fm

# 시스템에 설치된 폰트 중 한글 지원 폰트 찾기('나눔', '맑은' 포함 폰트)
font_list = [f.name for f in fm.fontManager.ttflist]
kor_fonts = [f for f in font_list if 'Nanum' in f or 'Malgun' in f]
if kor_fonts:
    plt.rcParams['font.family'] = kor_fonts[0]
    print(f"사용 폰트: {kor_fonts[0]}")
else:
    print("한글 폰트를 찾을 수 없습니다.")
# 한글 폰트 설정으로 인한 마이너스 기호 깨짐 방지
plt.rcParams['axes.unicode_minus'] = False

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle('Log Analyzer')
        self.setFixedSize(1200, 800)
        self.df = None  # 로그 데이터

        

        self.tabs = QTabWidget()
        self.setCentralWidget(self.tabs)

        # 탭 구성
        self.tabs.addTab(self.create_log_viewer(), '로그 뷰어')
        self.tabs.addTab(self.create_stats(), '통계')
        self.tabs.addTab(self.create_freq(), '메시지 빈도')

    def create_log_viewer(self):
        widget = QWidget()
        layout = QVBoxLayout()

        # 파일 불러오기 버튼
        self.load_btn = QPushButton('로그 파일 불러오기')
        self.load_btn.setStyleSheet('font-size: 14px; padding: 8px;')
        self.load_btn.clicked.connect(self.load_file)

        # 필터 버튼
        filter_layout = QHBoxLayout()
        self.filter_btns = {}
        for level in ['전체', 'INFO', 'WARNING', 'ERROR']:
            btn = QPushButton(level)
            btn.setStyleSheet('font-size: 13px; padding: 6px;')
            btn.clicked.connect(lambda _, l=level: self.filter_table(l))
            filter_layout.addWidget(btn)
            self.filter_btns[level] = btn

        # 검색창
        search_layout = QHBoxLayout()
        search_label = QLabel('검색:')
        search_label.setStyleSheet('font-size: 13px;')
        self.search_input = QLineEdit()
        self.search_input.setStyleSheet('font-size: 13px; padding: 4px;')
        self.search_input.setPlaceholderText('키워드 입력...')
        self.search_input.textChanged.connect(self.search_table)
        search_layout.addWidget(search_label)
        search_layout.addWidget(self.search_input)

        # 테이블
        self.table = QTableWidget()
        self.table.setColumnCount(3)
        self.table.setHorizontalHeaderLabels(['시간', '레벨', '메시지'])
        self.table.setColumnWidth(0, 200)
        self.table.setColumnWidth(1, 100)
        self.table.setColumnWidth(2, 850)
        self.table.setEditTriggers(QTableWidget.NoEditTriggers)

        layout.addWidget(self.load_btn)
        layout.addLayout(filter_layout)
        layout.addLayout(search_layout)
        layout.addWidget(self.table)
        widget.setLayout(layout)
        return widget

    def create_stats(self):
        widget = QWidget()
        layout = QVBoxLayout()

        self.stats_fig, self.stats_axes = plt.subplots(1, 2, figsize=(11, 6))
        self.stats_canvas = FigureCanvas(self.stats_fig)

        layout.addWidget(self.stats_canvas)
        widget.setLayout(layout)
        return widget
    

    def update_stats(self):
        if self.df is None:
            return

        counts = self.df['level'].value_counts()
        colors = {
            'INFO': '#ADD8E6',
            'WARNING': '#FFFFE0',
            'ERROR': '#FFC6D0'
        }
        chart_colors = [colors.get(l, '#CCCCCC') for l in counts.index]

        # 파이차트
        self.stats_axes[0].clear()
        self.stats_axes[0].pie(
            counts.values,
            labels=counts.index,
            colors=chart_colors,
            autopct='%1.1f%%',  # 소수점 밑 1자리까지 표시
            startangle=90
        )
        self.stats_axes[0].set_title('레벨별 비율')

        # 막대그래프
        self.stats_axes[1].clear()
        self.stats_axes[1].bar(counts.index, counts.values, color=chart_colors)
        self.stats_axes[1].set_title('레벨별 건수')
        self.stats_axes[1].set_xlabel('레벨')
        self.stats_axes[1].set_ylabel('건수')

        self.stats_fig.tight_layout()
        self.stats_canvas.draw()

    def create_freq(self):
        widget = QWidget()
        layout = QVBoxLayout()

        self.freq_fig, self.freq_ax = plt.subplots(figsize=(11, 6))
        self.freq_canvas = FigureCanvas(self.freq_fig)

        layout.addWidget(self.freq_canvas)
        widget.setLayout(layout)
        return widget

    def update_freq(self):
        if self.df is None:
            return

        counts = self.df['message'].value_counts()
        colors = []
        for msg in counts.index:
            # 해당 메시지의 레벨 확인
            level = self.df[self.df['message'] == msg]['level'].iloc[0]
            color_map = {
                'INFO': '#ADD8E6',
                'WARNING': '#FFFFE0',
                'ERROR': '#FFC6D0'
            }
            colors.append(color_map.get(level, '#CCCCCC'))

        self.freq_ax.clear()
        self.freq_ax.barh(counts.index, counts.values, color=colors)
        self.freq_ax.set_title('메시지 유형별 빈도')
        self.freq_ax.set_xlabel('건수')

        self.freq_fig.tight_layout()
        self.freq_canvas.draw()

    def load_file(self):
        filepath, _ = QFileDialog.getOpenFileName(
            self, '로그 파일 열기', '', 'Log Files (*.log *.txt)')
        if filepath:
            self.df = load_log(filepath)
            self.update_table(self.df)
            self.update_stats()
            self.update_freq()
            
    def update_table(self, df):
        df = df.reset_index(drop=True)
        self.table.setRowCount(len(df))
        colors = {
            'INFO': QColor(173, 216, 230),      # 연파랑
            'WARNING': QColor(255, 255, 224),    # 연노랑
            'ERROR': QColor(255, 198, 208)       # 연빨강
        }
        for i, row in df.iterrows():
            items = [str(row['time']), row['level'], row['message']]
            for j, text in enumerate(items):
                item = QTableWidgetItem(text)
                item.setBackground(colors.get(row['level'], QColor(255, 255, 255)))
                self.table.setItem(i, j, item)

    def filter_table(self, level):
        if self.df is None:
            return
        if level == '전체':
            self.update_table(self.df)
        else:
            self.update_table(self.df[self.df['level'] == level])

    def search_table(self, keyword):
        if self.df is None:
            return
        if keyword == '':
            self.update_table(self.df)
        else:
            filtered = self.df[self.df['message'].str.contains(keyword, na=False)]
            self.update_table(filtered)


app = QApplication(sys.argv)
window = MainWindow()
window.show()
sys.exit(app.exec_())